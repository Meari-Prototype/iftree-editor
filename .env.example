# IFTreeEditor 环境配置
# 复制此文件为 .env 并填入你的 API Key

# ── Ollama 本地模型（已安装则无需配置） ──
OLLAMA_BASE_URL=http://localhost:11434

# ── DeepSeek API（推荐，1M 上下文，足够处理数千句） ──
OPENAI_API_KEY=sk-your-deepseek-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro

# 设置页会自动维护以下字段，用于保存多个 LLM 摘要供应商和 API。
# IFTREE_LLM_ACTIVE_PROVIDER_ID=deepseek
# IFTREE_LLM_ACTIVE_API_ID=deepseek-default
# IFTREE_LLM_PROVIDERS_JSON={"providers":[{"id":"deepseek","name":"DeepSeek","note":"","websiteUrl":"https://api.deepseek.com","apis":[{"id":"deepseek-default","name":"默认 API","note":"","apiKey":"sk-your-deepseek-key","baseUrl":"https://api.deepseek.com","fullUrl":false,"model":"deepseek-v4-pro","enabled":true}]}]}

# 也支持显式 DeepSeek 命名；如果同时存在，DEEPSEEK_* 优先。
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-pro
