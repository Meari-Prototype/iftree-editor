# IFTreeEditor 环境配置
# 复制为 .env 后按需填写——所有变量都可选，只配你要用的那部分。.env 已在 .gitignore、不入库。

# ── 摘要 / 默认 LLM（OpenAI 兼容接口）──
# LLM 摘要、以及未单独配置时的内置问答 Agent 都走这里。
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro

# 显式 DeepSeek 命名（与 OPENAI_* 同在时 DEEPSEEK_* 优先）。
# DEEPSEEK_API_KEY=sk-your-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-pro

# ── 内置问答 Agent 直连（可选，覆盖上面的默认）──
# 想让内置 agent 用与摘要不同的模型（如本地 Ollama 小模型）时配这组；缺省复用 OPENAI_*/DEEPSEEK_*。
# IFTREE_AGENT_BASE_URL=http://localhost:11434/v1
# IFTREE_AGENT_MODEL=qwen3:8b
# IFTREE_AGENT_API_KEY=ollama
# IFTREE_AGENT_TIMEOUT_MS=45000     # 单轮超时，默认 45s；本地慢模型冷启动可调大

# ── 语义向量 / 嵌入后端（可选）──
# 缺省 transformers（本地内置模型，无需联网与 Key）。切远程嵌入服务时配这组。
# IFTREE_EMBED_BACKEND=ollama       # transformers（默认）| ollama | openai
# IFTREE_EMBED_BASE_URL=http://localhost:11434/v1
# IFTREE_EMBED_MODEL=nomic-embed-text
# IFTREE_EMBED_API_KEY=ollama
# IFTREE_EMBED_BATCH=16
# IFTREE_EMBED_FALLBACK=1           # 远程失败时回落本地 transformers（设 0 关闭）

# ── Ollama 本地服务（用 ollama 作对话 / 嵌入后端时）──
OLLAMA_BASE_URL=http://localhost:11434

# ── 设置页自动维护（一般不手编）──
# 应用设置页保存多供应商 / 多 API 时，会把配置写回以下字段（含各 API 的 Key，也只进 .env、不入库）。
# IFTREE_LLM_ACTIVE_PROVIDER_ID=deepseek
# IFTREE_LLM_PROVIDERS_JSON={...}
