{
  "name": "iftree-editor",
  "version": "0.6.2",
  "private": true,
  "license": "Apache-2.0",
  "author": "Meari",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "preapp": "npm run rebuild:native:node",
    "app": "electron .",
    "mcp": "electron scripts/mcp-server.mjs",
    "mcp:node": "node scripts/mcp-server.mjs",
    "build": "vite build",
    "lint": "eslint src electron scripts tests",
    "check:types": "tsc --noEmit -p tsconfig.check.json",
    "pretest": "npm run rebuild:native:node",
    "test": "node --test tests/*.test.mjs",
    "pretest:verbs": "npm run rebuild:native:node",
    "test:verbs": "node --test tests/db/*.test.mjs",
    "monitor:hardware": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/monitor-hardware.ps1",
    "verify:samples": "node scripts/verify-samples.mjs",
    "verify:chm": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-chm-e2e.ps1",
    "vectors:ensure": "node scripts/ensure-doc-vectors.mjs",
    "rebuild:native": "npm run rebuild:native:node",
    "rebuild:native:node": "node scripts/rebuild-native-node.mjs",
    "precheck:native": "npm run rebuild:native:node",
    "check:native": "node scripts/check-native.cjs",
    "check:native:node": "node scripts/check-native.cjs"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "fflate": "^0.8.2",
    "pdfjs-dist": "^5.7.284",
    "uuid": "^14.0.0"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^39.2.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vite": "^7.2.7"
  }
}
